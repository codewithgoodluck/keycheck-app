# Meta WhatsApp Cloud API (developers.facebook.com/docs/whatsapp)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=choose-any-string-you-want

# Firebase Admin — generate from Firebase Console > Project Settings > Service Accounts
# Option A (local dev): point at a downloaded JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Option B (most deployment hosts): paste the entire JSON key as one line here instead.
# If set, this takes priority over FIREBASE_SERVICE_ACCOUNT_PATH.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Storage bucket name (Firebase Console > Storage — looks like
# your-project-id.appspot.com). Required for evidence photo/document uploads.
FIREBASE_STORAGE_BUCKET=

# Link shown in bot messages, pointing at your deployed web app.
APP_LINK=https://your-keycheck-app.vercel.app

PORT=3000
