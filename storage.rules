rules_version = '2';

// Deploy with: firebase deploy --only storage
//
// Evidence uploads only. Anyone can upload (capped size + restricted
// file types, to prevent abuse), but nothing here is publicly readable —
// evidence may contain personal ID documents or other sensitive material,
// consistent with whatsapp-bot/mediaStorage.js's existing policy for
// bot-submitted evidence. Moderators view evidence via the Firebase
// Console (governed by project IAM, not these rules) until a dedicated
// admin-panel viewer exists.

service firebase.storage {
  match /b/{bucket}/o {
    match /evidence/{allPaths=**} {
      allow create: if request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*|application/pdf');
      allow read, update, delete: if false;
    }

    // Listing photos — publicly viewable (unlike evidence/, which is
    // private), since a listing photo is meant to be seen. Write still
    // requires being signed in (any lister, not just admins) to cut down
    // anonymous-upload abuse on a path anyone can read.
    match /listings/{allPaths=**} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow update, delete: if false;
    }

    // Site-wide banner image (see web/src/lib/siteSettings.js) —
    // admin-only, unlike listings/ which any signed-in lister can write
    // to. This is the image shown on every page's banner across the
    // whole app, not scoped to one listing, so it needs a higher trust
    // bar than "any authenticated user" — same bootstrap-email/moderator-
    // claim check as firestore.rules' isAdmin(), duplicated here since
    // Storage rules can't reference Firestore rules functions directly.
    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && (request.auth.token.moderator == true
                       || request.auth.token.email in ['goodluckmordi44@gmail.com'])
                   && (request.resource == null || (
                        request.resource.size < 10 * 1024 * 1024
                        && request.resource.contentType.matches('image/.*')
                      ));
    }
  }
}
