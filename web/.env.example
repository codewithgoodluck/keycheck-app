VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# WhatsApp Business number for the "report from your phone" link on the
# submit page, digits only with country code, no + or spaces (e.g. 2348012345678).
# Leave blank to keep the placeholder number.
VITE_WHATSAPP_NUMBER=

# Push notification groundwork only (see web/src/lib/push.js) — nothing
# currently sends a push, this just lets a device register to receive one
# in the future. Generate from Firebase Console > Project Settings >
# Cloud Messaging > Web Push certificates > "Generate key pair". Leave
# blank to disable the "notify me on this device" button entirely.
VITE_FIREBASE_VAPID_KEY=
