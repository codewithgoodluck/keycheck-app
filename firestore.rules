rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
// (requires the Firebase CLI: npm install -g firebase-tools, then firebase login)
//
// IMPORTANT: these rules are the actual security boundary. The admin panel's
// "sign in required" UI is just a convenience — anyone can call the Firestore
// API directly from a browser console, so these rules are what actually stops
// an unauthenticated person from marking their own report "verified" or
// deleting someone else's.
//
// These rules have NOT been tested against a live Firebase project from this
// environment (no network access to firebase.google.com here). Test them
// with the Firebase Emulator Suite (`firebase emulators:start`) or in a dev
// project before relying on them in production:
//   https://firebase.google.com/docs/rules/emulator-setup

service cloud.firestore {
  match /databases/{database}/documents {

    // Shared by every collection below, so it lives at the top level rather
    // than being duplicated per match block.
    function isAdmin() {
      // Two ways to qualify as a moderator:
      //  1. A 'moderator' custom claim, granted via scripts/set-moderator.js
      //     (the Admin SDK — this can't be self-granted from the client).
      //  2. The hardcoded bootstrap email below, for the very first
      //     moderator before any claim has been set up. Once every real
      //     moderator has the custom claim, drop this allowlist entirely so
      //     moderator identity lives in exactly one place.
      return request.auth != null
             && (request.auth.token.moderator == true
                 || request.auth.token.email in [
                   'goodluckmordi44@gmail.com'
                 ]);
    }

    match /reports/{reportId} {

      // Anyone can read reports — this is a public registry.
      allow read: if true;

      // Anyone can submit a new report, but only with safe defaults:
      // status must start "unverified" and upvotes must start at 0, so a
      // submitter can't mark their own report verified or pre-inflate it.
      allow create: if request.resource.data.status == 'unverified'
                    && request.resource.data.upvotes == 0;

      // Public updates are allowed ONLY for the two actions regular users
      // take: confirming ("I had this too") and adding a reply. Both are
      // restricted to changing just those fields — nothing else.
      allow update: if isOnlyConfirming() || isOnlyAddingReply();

      // Status changes, deleting a report, and editing existing replies
      // (e.g. marking identityVerified) are admin-only.
      allow update: if isAdmin();
      allow delete: if isAdmin();

      function isOnlyConfirming() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes'])
               && request.resource.data.upvotes == resource.data.upvotes + 1;
      }

      function isOnlyAddingReply() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies'])
               && request.resource.data.replies.size() == resource.data.replies.size() + 1;
      }
    }

    // Fire-and-forget log of searches that returned zero results (see
    // web/src/lib/reportsApi.js logSearchMiss). Purely an analytics signal
    // for moderators deciding what to seed next — nobody but a moderator
    // can read it, and the shape is locked down so it can't be abused to
    // store arbitrary data under a public-write collection.
    match /search_misses/{missId} {
      allow create: if request.resource.data.keys().hasOnly(['query', 'at'])
                    && request.resource.data.query is string
                    && request.resource.data.query.size() <= 200
                    && request.resource.data.at is string;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // FCM push token registry (see web/src/lib/push.js). Groundwork only —
    // nothing currently reads this to actually send a push; a future
    // Cloud Function or the whatsapp-bot service would use the Admin SDK
    // (which bypasses these rules) to query it. Not publicly readable:
    // listing every token would hand anyone a way to spam devices once a
    // real sender exists. Document ID is the token itself, so create and
    // update use the same shape check.
    match /push_subscriptions/{token} {
      allow create, update: if request.resource.data.keys().hasOnly(['token', 'watchedTerms', 'createdAt', 'updatedAt'])
                            && request.resource.data.token == token
                            && request.resource.data.watchedTerms is list
                            && request.resource.data.watchedTerms.size() <= 20;
      allow read: if isAdmin();
      allow delete: if false;
    }
  }
}
