rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
// (requires the Firebase CLI: npm install -g firebase-tools, then firebase login)
//
// IMPORTANT: these rules are the actual security boundary. The admin panel's
// "sign in required" UI is just a convenience — anyone can call the Firestore
// API directly from a browser console, so these rules are what actually stops
// an unauthenticated person from marking their own report "verified" or
// deleting someone else's.
//
// These rules have NOT been tested against a live Firebase project from this
// environment (no network access to firebase.google.com here). Test them
// with the Firebase Emulator Suite (`firebase emulators:start`) or in a dev
// project before relying on them in production:
//   https://firebase.google.com/docs/rules/emulator-setup

service cloud.firestore {
  match /databases/{database}/documents {

    // Shared by every collection below, so it lives at the top level rather
    // than being duplicated per match block.
    function isAdmin() {
      // Two ways to qualify as a moderator:
      //  1. A 'moderator' custom claim, granted via scripts/set-moderator.js
      //     (the Admin SDK — this can't be self-granted from the client).
      //  2. The hardcoded bootstrap email below, for the very first
      //     moderator before any claim has been set up. Once every real
      //     moderator has the custom claim, drop this allowlist entirely so
      //     moderator identity lives in exactly one place.
      return request.auth != null
             && (request.auth.token.moderator == true
                 || request.auth.token.email in [
                   'goodluckmordi44@gmail.com'
                 ]);
    }

    match /reports/{reportId} {

      // Anyone can read reports — this is a public registry.
      allow read: if true;

      // Anyone can submit a new report, but only with safe defaults:
      // status must start "unverified" and upvotes must start at 0, so a
      // submitter can't mark their own report verified or pre-inflate it.
      //
      // Also requires a minimum evidentiary bar, enforced here (not just
      // client-side) because client-side checks are trivially bypassable
      // via a direct API call: attestedAccuracy must be true (a good-faith
      // attestation on every single submission — cheap, but creates a
      // paper trail that matters for defamation-risk mitigation), AND at
      // least one of: an evidence file, a public source link, or a
      // sufficiently specific (non-trivial-length) description. This is a
      // deliberate policy decision to reduce baseless accusations going
      // live with zero substantiation — see the moderation policy
      // discussion this was built from.
      allow create: if request.resource.data.status == 'unverified'
                    && request.resource.data.upvotes == 0
                    && request.resource.data.attestedAccuracy == true
                    && hasMinimumEvidence();

      // Public updates are allowed ONLY for the two actions regular users
      // take: confirming ("I had this too") and adding a reply. Both are
      // restricted to changing just those fields — nothing else.
      allow update: if isOnlyConfirming() || isOnlyAddingReply();

      // Status changes, deleting a report, and editing existing replies
      // (e.g. marking identityVerified) are admin-only. A report can only
      // be (or remain) "verified" if it has a real source attached —
      // applies to every admin update, not just the transition itself, so
      // a source can't be removed later while verified status stays set.
      allow update: if isAdmin() && isValidVerifiedState();
      allow delete: if isAdmin();

      function hasMinimumEvidence() {
        return (request.resource.data.evidenceUrls is list && request.resource.data.evidenceUrls.size() > 0)
               || (request.resource.data.sourceUrl is string && request.resource.data.sourceUrl.size() > 0)
               || (request.resource.data.description is string && request.resource.data.description.size() >= 60);
      }

      function isValidVerifiedState() {
        return request.resource.data.status != 'verified'
               || (request.resource.data.sourceUrl is string && request.resource.data.sourceUrl.size() > 0)
               || (request.resource.data.get('additionalSources', []).size() > 0);
      }

      function isOnlyConfirming() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes'])
               && request.resource.data.upvotes == resource.data.upvotes + 1;
      }

      function isOnlyAddingReply() {
        // resource.data.get('replies', []) rather than resource.data.replies:
        // reports created via the web form or the seed script never
        // initialize a `replies` field (it's added lazily by the first
        // reply's arrayUnion write), so a direct .replies.size() access
        // errors out on that first reply attempt — silently denying the
        // write and making it look like replies just don't work.
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies'])
               && request.resource.data.replies.size() == resource.data.get('replies', []).size() + 1;
      }
    }

    // Fire-and-forget log of searches that returned zero results (see
    // web/src/lib/reportsApi.js logSearchMiss). Purely an analytics signal
    // for moderators deciding what to seed next — nobody but a moderator
    // can read it, and the shape is locked down so it can't be abused to
    // store arbitrary data under a public-write collection.
    match /search_misses/{missId} {
      allow create: if request.resource.data.keys().hasOnly(['query', 'at'])
                    && request.resource.data.query is string
                    && request.resource.data.query.size() <= 200
                    && request.resource.data.at is string;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Verified Listings. Milestone 2 adds self-serve lister accounts —
    // a lister is any authenticated Firebase Auth user who is NOT an
    // admin (no separate Auth instance; distinguished purely by the
    // absence of the moderator claim). Admin-direct creation from
    // Milestone 1 still works via isAdmin().
    match /listings/{listingId} {
      // Public sees only active listings. Admins see everything. A
      // lister can see their own listing at any status (their "My
      // listings" dashboard needs pending/rejected visibility too).
      allow read: if resource.data.status == 'active'
                  || isAdmin()
                  || (request.auth != null && request.auth.uid == resource.data.listerId);

      // Self-serve creation always starts 'pending' — never publicly
      // visible until a moderator activates it (see isValidListingActivation()
      // note: the auto-block-flagged-agents check itself runs
      // client-side in listingsApi.js at *activation* time, not here —
      // re-checking it in rules would need a cross-collection get() on
      // every listing read/write, and the only path that makes a
      // listing public is the admin activation flow, which is already
      // the trust boundary this app relies on elsewhere (e.g. isAdmin()
      // can already set a report's status to anything).
      allow create: if request.auth != null
                    && !isAdmin()
                    && request.resource.data.listerId == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Admins can do anything (activate, reject, edit, delete — same
      // trust boundary as reports). A lister can only edit their own
      // listing, and only within safe transitions: editing content while
      // still pending, or moving freely among the five post-approval
      // lifecycle states (active/under_offer/let/sold/expired) in either
      // direction — e.g. "Renew" needs expired -> active, which a
      // one-directional rule would reject. Never self-approving to
      // 'active' from 'pending', never entering/leaving 'rejected', never
      // reassigning listerId to someone else.
      allow update: if isAdmin()
                    || (request.auth != null
                        && request.auth.uid == resource.data.listerId
                        && isOwnerAllowedListingUpdate());
      allow delete: if isAdmin()
                    || (request.auth != null
                        && request.auth.uid == resource.data.listerId
                        && resource.data.status != 'active');

      function isOwnerAllowedListingUpdate() {
        return request.resource.data.listerId == resource.data.listerId
               && (
                 (resource.data.status == 'pending' && request.resource.data.status == 'pending')
                 || (resource.data.status in ['active', 'under_offer', 'let', 'sold', 'expired']
                     && request.resource.data.status in ['active', 'under_offer', 'let', 'sold', 'expired'])
               );
      }
    }

    // Lightweight inquiry leads (see web/src/components/InquiryForm.jsx)
    // — the "in-app messaging" alternative: a one-off contact form, not a
    // conversation, so no buyer account is needed. Contains a buyer's
    // personal contact info, so — like evidence/ in Storage — this is
    // never publicly readable, only by the owning lister or an admin.
    match /inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasOnly(
                         ['listingId', 'listerId', 'listingLocationText', 'buyerName', 'buyerContact', 'message', 'createdAt', 'read']
                       )
                    && request.resource.data.listingId is string
                    && request.resource.data.listerId is string
                    && request.resource.data.buyerName is string && request.resource.data.buyerName.size() <= 100
                    && request.resource.data.buyerContact is string && request.resource.data.buyerContact.size() <= 100
                    && request.resource.data.message is string && request.resource.data.message.size() <= 1000
                    && request.resource.data.read == false;

      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.listerId);

      allow update: if (isAdmin() || (request.auth != null && request.auth.uid == resource.data.listerId))
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.listerId);
    }

    // View-count analytics (see web/src/lib/listingsApi.js's
    // logListingView/getListingViewCount) — fire-and-forget log, same
    // shape/spirit as search_misses below. listerId is denormalized onto
    // the view-log doc itself (the viewer already has it from the public
    // listing they just read) so the read/count rule can check ownership
    // directly without a cross-collection get(). No dedup — every page
    // load logs a view, a deliberate simplification (see the plan).
    match /listing_views/{viewId} {
      allow create: if request.resource.data.keys().hasOnly(['listingId', 'listerId', 'at'])
                    && request.resource.data.listingId is string
                    && request.resource.data.listerId is string
                    && request.resource.data.at is string;
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.listerId);
      allow update, delete: if false;
    }

    // FCM push token registry (see web/src/lib/push.js). Groundwork only —
    // nothing currently reads this to actually send a push; a future
    // Cloud Function or the whatsapp-bot service would use the Admin SDK
    // (which bypasses these rules) to query it. Not publicly readable:
    // listing every token would hand anyone a way to spam devices once a
    // real sender exists. Document ID is the token itself, so create and
    // update use the same shape check.
    match /push_subscriptions/{token} {
      allow create, update: if request.resource.data.keys().hasOnly(['token', 'watchedTerms', 'createdAt', 'updatedAt'])
                            && request.resource.data.token == token
                            && request.resource.data.watchedTerms is list
                            && request.resource.data.watchedTerms.size() <= 20;
      allow read: if isAdmin();
      allow delete: if false;
    }
  }
}
